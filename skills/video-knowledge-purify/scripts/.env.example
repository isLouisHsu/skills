# 视频知识提纯器 - 环境变量配置
# 复制此文件为 .env 并填入你的实际配置

# ========== 分段模型配置（文本 LLM）==========
# 用于视频内容分段，按主题语义切分字幕
# 建议使用便宜快速的文本模型，如 qwen-turbo、gpt-4o-mini 等
SRT_SEGMENTER_BASE_URL=
SRT_SEGMENTER_API_KEY=
SRT_SEGMENTER_MODEL=

# ========== 汇总模型配置（VLM，需要视觉能力）==========
# 用于视频内容汇总，结合字幕和视频帧生成笔记
# 需要支持视觉的模型，如 qwen-vl-plus、gpt-4o 等
SRT_MERGER_BASE_URL=
SRT_MERGER_API_KEY=
SRT_MERGER_MODEL=
